(primCol.modes[0].modeId, 'Value')\nconst primMode = primCol.modes[0].modeId\n\nfor (const part of PACKED.split('|')) {\n  const til = part.indexOf('~')\n  const nm = part.slice(0, til)\n  const varName = 'raw/' + nm\n  const rid = rawIds[varName]\n  const pv = figma.variables.createVariable(nm, primCol, 'COLOR')\n  pv.scopes = nm.includes('contrast-text')\n    ? ['TEXT_FILL']\n    : ['FRAME_FILL', 'SHAPE_FILL', 'TEXT_FILL', 'STROKE_COLOR']\n  pv.setValueForMode(primMode, { type: 'VARIABLE_ALIAS', id: rid })\n  pv.setVariableCodeSyntax('WEB', 'var(--' + nm.replace(/[\\s\\/%,]+/g, '-') + ')')\n}\n\nreturn { rawCount: Object.keys(rawIds).length, primitiveCount: PACKED.split('|').length }\n"}}